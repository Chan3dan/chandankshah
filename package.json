{
  "name": "cks-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev:server": "node --experimental-strip-types server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "docker:up": "docker compose -f docker-compose.local.yml up -d",
    "docker:down": "docker compose -f docker-compose.local.yml down",
    "docker:full": "docker compose up -d",
    "docker:logs": "docker compose -f docker-compose.local.yml logs -f",
    "docker:reset": "docker compose -f docker-compose.local.yml down -v && docker compose -f docker-compose.local.yml up -d",
    "seed": "node --experimental-strip-types scripts/seed-cli.ts",
    "seed:force": "node --experimental-strip-types scripts/seed-cli.ts --force",
    "seed:reset": "node --experimental-strip-types scripts/seed-cli.ts --reset",
    "local:start": "npm run seed && npm run dev:all",
    "seed:node": "node --experimental-strip-types scripts/seed-cli.ts"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.11.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "cloudinary": "^2.9.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "mongoose": "^9.4.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-color": "^2.19.3",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.12.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "morgan": "^1.10.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
