# ================================================================
#  CKS WEBSITE — Example Environment Variables
#  Copy this to .env.local and fill in your real values.
#  NEVER commit real secrets to GitHub.
# ================================================================

# ----------------------------------------------------------------
# MongoDB
# Use MongoDB Atlas in production.
# ----------------------------------------------------------------
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cks_website?retryWrites=true&w=majority&appName=Cluster0

# ----------------------------------------------------------------
# NextAuth — REQUIRED
# Generate AUTH_SECRET with: openssl rand -base64 32
# ----------------------------------------------------------------
AUTH_SECRET=replace-with-a-random-32-byte-secret
NEXTAUTH_URL=http://localhost:3000

# ----------------------------------------------------------------
# Google OAuth — from console.cloud.google.com
# ----------------------------------------------------------------
AUTH_GOOGLE_ID=replace-with-google-client-id
AUTH_GOOGLE_SECRET=replace-with-google-client-secret

# ----------------------------------------------------------------
# Admin Access
# ----------------------------------------------------------------
ADMIN_EMAIL=you@example.com

# ----------------------------------------------------------------
# Optional: Email (Resend)
# ----------------------------------------------------------------
RESEND_API_KEY=re_replace_me
EMAIL_FROM=hello@chandankshah.com.np
EMAIL_TO=you@example.com

# ----------------------------------------------------------------
# Optional: Image Upload (Cloudinary)
# ----------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# ----------------------------------------------------------------
# Optional: Cloudflare Turnstile
# ----------------------------------------------------------------
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
